{
	"compilerOptions": {
		"types": ["node"],
		"target": "ES2020",
		"module": "commonjs",
		"outDir": "dist",
		"rootDir": "src",
		"lib": ["ES2020"],
		"strict": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"sourceMap": true,
		"resolveJsonModule": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
